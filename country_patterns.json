{
  "Indonesia": {
    "name_pattern": "IDN([A-Z]+)<<([A-Z]+)",
    "passport_pattern": "\\b([A-Z]{1}\\d{7})\\b"
  },
  "Morocco": {
    "name_pattern": "MAR([A-Z]+)<<([A-Z]+)",
    "passport_pattern": "([A-Z]{2}\\d{7})"
  },
  "Iraq": {
    "name_pattern": "IRQ([A-Z]+)<<([A-Z]+)",
    "passport_pattern": "\\b([A-Z]{1}\\d{8})\\b"
  },
  "Nigeria": {
    "name_pattern": "NGA([A-Z]+)<<([A-Z]+)",
    "passport_pattern": "\\b([A-Z]{1}\\d{8})\\b"
  },
  "India": {
    "name_pattern": "IND([A-Z]+)<<([A-Z]+)",
    "passport_pattern": "\\b([A-Z]{1}\\d{7}|[A-Z]{2}\\d{6})\\b"
  },
  "Lebanon": {
    "name_pattern": "LBN([A-Z]+)<<([A-Z]+)",
    "passport_pattern": "\\b([A-Z]{2}\\d{7})\\b"
  },
  "Egypt": {
    "name_pattern": "EGY([A-Z]+)<<([A-Z]+)",
    "passport_pattern": "\\b([A-Z]{1}\\d{8})\\b" 
  },
  "Algeria": {
    "name_pattern":"DZA([A-Z]+)<<([A-Z]+)",
    "passport_pattern": "(?<!\\d)(3\\d{8})(?!\\d)"
    
  },
  "Malaysia" : {
    "name_pattern": "MYS([A-Z]+)<<([A-Z]+)",
    "passport_pattern": "\\b([A-Z]{1}\\d{8})\\b"
}
}