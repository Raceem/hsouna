+def _normalize_gender(value: str | None) -> str | None:
+    if value is None:
+        return None
+    s = str(value).strip().lower()
+    if not s:
+        return None
+    if s in {"h", "m", "homme", "male", "man", "masculin"}:
+        return "H"
+    if s in {"f", "femme", "female", "woman", "feminin"}:
+        return "F"
+    return None
+
